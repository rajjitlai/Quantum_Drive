# Quantum Drive Configuration - Example Environment File
# Rename this file to .env and configure the variables below.

# The folder on the host machine you want to share (e.g. C:\Shared)
SHARED_FOLDER=shared_files

# Plain text access password (required for login)
ACCESS_PASSWORD=your-secure-password-here

# Flask session secret key. 
# Leave blank or commented out to automatically generate a random key on each startup (recommended).
# SECRET_KEY=
